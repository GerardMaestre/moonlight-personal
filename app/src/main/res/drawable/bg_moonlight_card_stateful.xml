<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <stroke android:width="1dp" android:color="#33ADC6FF" />
            <gradient android:startColor="#1FFFFFFF" android:endColor="#08FFFFFF" android:angle="270" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <stroke android:width="2dp" android:color="#66ADC6FF" />
            <gradient android:startColor="#18FFFFFF" android:endColor="#0810131B" android:angle="270" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <stroke android:width="1dp" android:color="@color/ml_glass_border" />
            <gradient android:startColor="#10FFFFFF" android:endColor="#0510131B" android:angle="270" />
        </shape>
    </item>
</selector>
