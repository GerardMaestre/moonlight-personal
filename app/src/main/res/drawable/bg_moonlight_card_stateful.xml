<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ml_radius_md" />
            <solid android:color="@color/ml_state_pressed" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ml_radius_md" />
            <stroke android:width="2dp" android:color="@color/ml_state_focused" />
            <solid android:color="@color/ml_surface_variant" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ml_radius_md" />
            <solid android:color="@color/ml_card_background" />
        </shape>
    </item>
</selector>
