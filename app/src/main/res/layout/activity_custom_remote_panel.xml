<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/custom_panel_title"
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/custom_panel_summary"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <CheckBox
            android:id="@+id/customEnableDirectHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/custom_enable_direct_host" />

        <EditText
            android:id="@+id/customHostName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/custom_host_name"
            android:inputType="textCapWords"
            android:singleLine="true" />

        <EditText
            android:id="@+id/customHostAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/custom_host_address"
            android:inputType="textUri"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/customHttpPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/custom_http_port"
                android:inputType="number"
                android:singleLine="true" />

            <EditText
                android:id="@+id/customHttpsPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:hint="@string/custom_https_port"
                android:inputType="number"
                android:singleLine="true" />
        </LinearLayout>

        <EditText
            android:id="@+id/customMacAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/custom_mac_address"
            android:inputType="text"
            android:singleLine="true" />

        <CheckBox
            android:id="@+id/customEnableBridge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/custom_enable_bridge" />

        <EditText
            android:id="@+id/customBridgeUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/custom_bridge_url"
            android:inputType="textUri"
            android:singleLine="true" />

        <RadioGroup
            android:id="@+id/customBridgeMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/customBridgeGet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/custom_bridge_get" />

            <RadioButton
                android:id="@+id/customBridgePost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginStart="24dp"
                android:text="@string/custom_bridge_post" />
        </RadioGroup>

        <EditText
            android:id="@+id/customBridgeTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/custom_bridge_timeout"
            android:inputType="number"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/customSaveButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/custom_save" />

            <Button
                android:id="@+id/customPrepareButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/custom_prepare_pc" />

            <Button
                android:id="@+id/customWolButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/custom_send_wol" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/custom_profiles_title"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/customHomeProfileButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/custom_profile_home" />

            <Button
                android:id="@+id/customFiveGProfileButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/custom_profile_5g" />

            <Button
                android:id="@+id/customSaverProfileButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/custom_profile_saver" />
        </LinearLayout>

        <TextView
            android:id="@+id/customStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:minHeight="64dp"
            android:text="@string/custom_status_idle"
            android:textAppearance="?android:attr/textAppearanceMedium" />
    </LinearLayout>
</ScrollView>
