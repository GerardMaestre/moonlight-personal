<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:duration="120"
                android:interpolator="@android:interpolator/accelerate_decelerate"
                android:propertyName="scaleX"
                android:valueTo="0.96"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="120"
                android:interpolator="@android:interpolator/accelerate_decelerate"
                android:propertyName="scaleY"
                android:valueTo="0.96"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="120"
                android:propertyName="translationZ"
                android:valueTo="1dp"
                android:valueType="floatType" />
            <objectAnimator
                android:duration="120"
                android:propertyName="alpha"
                android:valueTo="0.85"
                android:valueType="floatType" />
        </set>
    </item>
    <item>
        <set>
            <objectAnimator android:duration="180" android:propertyName="scaleX" android:valueTo="1" android:valueType="floatType" />
            <objectAnimator android:duration="180" android:propertyName="scaleY" android:valueTo="1" android:valueType="floatType" />
            <objectAnimator android:duration="180" android:propertyName="translationZ" android:valueTo="4dp" android:valueType="floatType" />
            <objectAnimator android:duration="180" android:propertyName="alpha" android:valueTo="1" android:valueType="floatType" />
        </set>
    </item>
</selector>
