<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ThemeTokens" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ml_primary</item>
        <item name="colorOnPrimary">@color/ml_on_primary</item>
        <item name="colorPrimaryContainer">@color/ml_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/ml_on_primary_container</item>
        <item name="colorSecondary">@color/ml_secondary</item>
        <item name="colorOnSecondary">@color/ml_on_secondary</item>
        <item name="colorSecondaryContainer">@color/ml_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/ml_on_secondary_container</item>
        <item name="colorTertiary">@color/ml_tertiary</item>
        <item name="colorOnTertiary">@color/ml_on_tertiary</item>
        <item name="android:colorBackground">@color/ml_background</item>
        <item name="colorOnBackground">@color/ml_on_background</item>
        <item name="colorSurface">@color/ml_surface</item>
        <item name="colorOnSurface">@color/ml_on_surface</item>
        <item name="colorSurfaceVariant">@color/ml_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/ml_on_surface_variant</item>
        <item name="colorOutline">@color/ml_outline</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/ml_background</item>
        <item name="android:colorAccent">@color/ml_primary</item>
        <item name="colorError">@color/ml_error</item>
        <item name="colorOnError">@color/ml_on_error</item>

        <item name="shapeAppearanceSmallComponent">@style/Shape.Moonlight.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.Moonlight.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.Moonlight.Large</item>
    </style>

    <style name="Shape.Moonlight.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerSize">@dimen/ml_radius_sm</item>
    </style>
    <style name="Shape.Moonlight.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">@dimen/ml_radius_md</item>
    </style>
    <style name="Shape.Moonlight.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">@dimen/ml_radius_lg</item>
    </style>

    <style name="Typography.Moonlight.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/ml_text_body</item>
    </style>
    <style name="Typography.Moonlight.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/ml_text_title</item>
    </style>
</resources>
