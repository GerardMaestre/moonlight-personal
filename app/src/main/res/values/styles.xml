<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppBaseTheme" parent="ThemeTokens" />

    <style name="AppTheme" parent="AppBaseTheme">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="StreamBaseTheme" parent="AppBaseTheme">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="StreamTheme" parent="StreamBaseTheme">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Widget.Moonlight.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/ml_button_min_height</item>
        <item name="android:paddingStart">@dimen/ml_space_lg</item>
        <item name="android:paddingEnd">@dimen/ml_space_lg</item>
        <item name="android:textAppearance">@style/Typography.Moonlight.Body</item>
        <item name="android:background">@drawable/bg_moonlight_button_stateful</item>
    </style>

    <style name="Widget.Moonlight.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/ml_radius_md</item>
        <item name="cardElevation">@dimen/ml_elevation_2</item>
        <item name="cardBackgroundColor">@color/ml_card_background</item>
        <item name="contentPadding">@dimen/ml_space_lg</item>
    </style>

    <style name="Widget.Moonlight.ListItem" parent="@android:style/Widget.ListView">
        <item name="android:listSelector">@drawable/bg_moonlight_list_item_stateful</item>
        <item name="android:dividerHeight">@dimen/ml_space_xs</item>
    </style>

    <style name="Widget.Moonlight.FocusableContainer">
        <item name="android:background">@drawable/bg_moonlight_focusable_stateful</item>
        <item name="android:padding">@dimen/ml_space_lg</item>
    </style>

    <style name="UnifiedIconButton" parent="?android:attr/borderlessButtonStyle">
        <item name="android:stateListAnimator">@animator/button_touch_feedback</item>
    </style>
</resources>
